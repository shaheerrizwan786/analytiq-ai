GOOGLE_API_KEY=
APIFY_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=

# Optional Apify overrides (defaults shown - only set these to override)
# Stage 1: Get place URL from search
APIFY_GOOGLE_ACTOR_ID=compass/crawler-google-places
# Google Search Scraper for finding TripAdvisor/Yelp URLs
APIFY_GOOGLE_SEARCH_ACTOR_ID=apify/google-search-scraper
# Stage 2: Extract detailed reviews with context and detailed ratings
APIFY_GOOGLE_REVIEWS_ACTOR_ID=compass/Google-Maps-Reviews-Scraper
APIFY_YELP_ACTOR_ID=tri_angle/yelp-review-scraper
APIFY_YELP_DISCOVERY_ACTOR_ID=tri_angle/yelp-scraper
APIFY_YELP_DISCOVERY_SEARCH_LIMIT=3
# delicious_zebu/tripadvisor-review-collector (default) or legacy maxcopell/tripadvisor-reviews
APIFY_TRIPADVISOR_ACTOR_ID=delicious_zebu/tripadvisor-review-collector
APIFY_TRIPADVISOR_DISCOVERY_ACTOR_ID=maxcopell/tripadvisor

# Yelp is currently blocked (403 on all requests). Set to false to disable.
APIFY_YELP_ENABLED=false

# Review limits per source
APIFY_GOOGLE_MAX_REVIEWS=100
APIFY_TRIPADVISOR_MAX_REVIEWS=100
APIFY_YELP_MAX_REVIEWS=100
APIFY_WAIT_SECS=900

# Apify actor memory (MB on Apify Cloud) — Google reviews largest; search URL smallest
APIFY_MEMORY_GOOGLE_REVIEWS_MB=2048
APIFY_MEMORY_GOOGLE_PLACES_MB=1024
APIFY_MEMORY_TRIPADVISOR_REVIEWS_MB=768
APIFY_MEMORY_YELP_REVIEWS_MB=512
APIFY_MEMORY_GOOGLE_SEARCH_MB=256
APIFY_MEMORY_DISCOVERY_MB=512

# Apify Cloud memory (actors run on Apify). Budget ≈ your plan limit; peak ≈ one full analyze.
# Example: 8192 / ~3584 ≈ 2 concurrent analyses before queueing.
APIFY_PLATFORM_MEMORY_BUDGET_MB=8192
# Leave 0 to auto-estimate from APIFY_MEMORY_* below
APIFY_ANALYSIS_PEAK_MEMORY_MB=0
# Set to true to include reviews without text (empty comments) in extraction and sentiment analysis
INCLUDE_EMPTY_REVIEWS=false

# Database connection string (e.g. for PostgreSQL: postgresql://user:password@localhost:5432/dbname)
DATABASE_URL=

# FastAPI - comma-separated browser origins (Next dev default)
CORS_ORIGINS=http://localhost:3000

# Next.js - when calling FastAPI from the browser during dev
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Internal API key - set a strong random string to protect backend endpoints
# Backend reads: INTERNAL_API_KEY
# Frontend sends: NEXT_PUBLIC_INTERNAL_API_KEY (visible in browser bundle, acts as basic abuse barrier)
INTERNAL_API_KEY=
NEXT_PUBLIC_INTERNAL_API_KEY=
