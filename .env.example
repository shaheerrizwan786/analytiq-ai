GOOGLE_API_KEY=
APIFY_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=

# Optional Apify overrides
 # Stage 1: Get place URL from search
 APIFY_GOOGLE_ACTOR_ID=compass/crawler-google-places
 # Google Search Scraper for finding TripAdvisor/Yelp URLs
 APIFY_GOOGLE_SEARCH_ACTOR_ID=apify/google-search-scraper
 # Stage 2: Extract detailed reviews with context and detailed ratings
 APIFY_GOOGLE_REVIEWS_ACTOR_ID=compass/Google-Maps-Reviews-Scraper
 APIFY_YELP_ACTOR_ID=tri_angle/yelp-review-scraper
 APIFY_YELP_DISCOVERY_ACTOR_ID=tri_angle/yelp-scraper
 APIFY_YELP_DISCOVERY_SEARCH_LIMIT=3
 APIFY_TRIPADVISOR_ACTOR_ID=maxcopell/tripadvisor-reviews
 APIFY_TRIPADVISOR_DISCOVERY_ACTOR_ID=maxcopell/tripadvisor

# Yelp is currently blocked (403 on all requests). Set to false to disable.
APIFY_YELP_ENABLED=false

# Review limits per source
APIFY_GOOGLE_MAX_REVIEWS=100
APIFY_TRIPADVISOR_MAX_REVIEWS=100
APIFY_YELP_MAX_REVIEWS=100
APIFY_WAIT_SECS=900
# Set to true to include reviews without text (empty comments) in extraction and sentiment analysis
INCLUDE_EMPTY_REVIEWS=false

# Database connection string (e.g. for PostgreSQL: postgresql://user:password@localhost:5432/dbname)
DATABASE_URL=

# FastAPI — comma-separated browser origins (Next dev default)
CORS_ORIGINS=http://localhost:3000

# Next.js — when calling FastAPI from the browser during dev
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

